(ns build
  (:import
   (System.IO Directory)))

(def target-dir "assemblies")

(defn run-aot!
  [& {:as _opts}]
  (when-not (Directory/Exists target-dir)
    (Directory/CreateDirectory target-dir))
  (binding [*compile-path* target-dir]
    (println "AOT compiling to:" *compile-path*)
    (compile 'foo.core)))
